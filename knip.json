{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "e2e/**/*.{ts,tsx}"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "e2e/**/*.{ts,tsx}",
    "gen/*.ts",
    "scripts/**/*.js"
  ],
  "ignore": [
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "dist/**",
    "coverage/**",
    "gen/centy/v1/**",
    "types/**/*.d.ts",
    "__tests__/**"
  ],
  "ignoreBinaries": ["serve"],
  "ignoreDependencies": [
    "@bufbuild/protoc-gen-es",
    "baseline-browser-mapping",
    "@centy-io/assets",
    "@cspell/dict-he",
    "import-in-the-middle",
    "msw",
    "require-in-the-middle",
    "serve"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreWorkspaces": []
}
