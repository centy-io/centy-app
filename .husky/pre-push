echo "Running pre-push checks..."

echo "Checking proto submodule is up to date with main..."
PROTO_PATH="proto"
PROTO_CURRENT=$(git submodule status "$PROTO_PATH" | awk '{print $1}' | tr -d '+-')
PROTO_REMOTE=$(git ls-remote git@github.com:centy-io/proto.git refs/heads/main | awk '{print $1}')
if [ "$PROTO_CURRENT" != "$PROTO_REMOTE" ]; then
  echo "Proto submodule is not up to date with main."
  echo "Current: $PROTO_CURRENT"
  echo "Remote main: $PROTO_REMOTE"
  echo "Run 'git submodule update --remote proto' to update."
  exit 1
fi

echo "Checking linting..."
pnpm lint || {
  echo "Linting failed. Please fix errors before pushing."
  exit 1
}

echo "Checking formatting..."
pnpm format:check || {
  echo "Formatting check failed. Run 'pnpm format' to fix."
  exit 1
}

echo "Checking spelling..."
pnpm spell || {
  echo "Spell check failed. Please fix spelling errors."
  exit 1
}

echo "Checking for unused code..."
pnpm knip || {
  echo "Knip found unused code. Please review and fix."
  exit 1
}

echo "Running tests..."
pnpm test --run || {
  echo "Tests failed. Please fix failing tests before pushing."
  exit 1
}

echo "Running visual regression tests..."
pnpm e2e:visual:pre-push || {
  echo "Visual regression tests failed."
  echo "If your changes intentionally affect the UI, update snapshots with:"
  echo "  pnpm e2e:visual:pre-push:update"
  exit 1
}

echo "All pre-push checks passed!"
