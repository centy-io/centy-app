# Required environment variables for building centy-app.
# Copy this file to .env.local for local development.

# URL of the local centy daemon gRPC server
NEXT_PUBLIC_DAEMON_URL=http://localhost:50051

# URL of the centy documentation site
NEXT_PUBLIC_DOCS_URL=https://docs.centy.io

# URL of the centy daemon installer script
NEXT_PUBLIC_DAEMON_INSTALL_URL=https://github.com/centy-io/installer/releases/latest/download/install.sh

# CORS-allowed origin for documentation requests
NEXT_PUBLIC_CORS_DOCS_URL=https://app.centy.io

# Google Analytics script URL
NEXT_PUBLIC_GOOGLE_ANALYTICS_URL=https://www.googletagmanager.com/gtag/js?id=G-ZV5SD70Z2D

# Sentry DSN for error reporting
NEXT_PUBLIC_SENTRY_DSN=https://98aef6a0676becdbe5b6a8a8ee14b8d3@o4510682522976256.ingest.de.sentry.io/4510682527367248
